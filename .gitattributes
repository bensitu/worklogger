# Enforce LF line endings for all text files in the repository.
# This prevents CRLF/LF mixed-mode issues on Windows checkouts.

*           text=auto eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
*.ics       text eol=lf

# Binary assets — never convert
*.db        binary
*.icns      binary
*.ico       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
